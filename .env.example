# Copy this file to .env and fill in your values
# cp .env.example .env

# --- OpenAI ---
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# --- Deepgram ---
# Sign up at https://deepgram.com — $200 free credit
DEEPGRAM_API_KEY=...
DEEPGRAM_MODEL=nova-2
DEEPGRAM_LANGUAGE=en-US
# TTS voice when TTS_PROVIDER=deepgram (Aura English models)
DEEPGRAM_TTS_VOICE=aura-asteria-en
# Deepgram TTS HTTPS: default is no cert verify (Homebrew Python 3.14 SSL issues). Set true in prod.
# DEEPGRAM_TTS_SSL_VERIFY=true

# TTS provider: "elevenlabs" (best quality), "openai" (natural, no extra cost), "deepgram" (free credits)
TTS_PROVIDER=openai

# --- OpenAI TTS (only used when TTS_PROVIDER=openai) ---
# Voice options: nova | alloy | echo | fable | onyx | shimmer
OPENAI_TTS_VOICE=nova
# Model: tts-1 (fast, good) | tts-1-hd (slower, higher quality)
OPENAI_TTS_MODEL=tts-1

# --- ElevenLabs ---
# Sign up at https://elevenlabs.io — 10k chars/month free
ELEVENLABS_API_KEY=...
# Voice: "George" (professional, clear) — find others at https://elevenlabs.io/voice-library
ELEVENLABS_VOICE_ID=JBFqnCBsd6RMkjVDRZzb

# --- App ---
# Comma-separated allowed CORS origins
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]
LOG_LEVEL=INFO
